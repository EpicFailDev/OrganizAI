# ==========================================
# OrganizAI - Root Gitignore for Monorepo
# ==========================================

# Dependency directories
node_modules/
jspm_packages/
web_resources/

# Web Build Outputs
dist/
build/
out/
.next/
.nuxt/

# Secrets & Environment Variables (CRITICAL!)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env
*.env.*
!.env.example

# IDEs, Text Editors, and OS Metadata
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store
Thumbs.db
desktop.ini

# Logs and databases
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.log
*.sqlite

# Testing
/coverage
/.nyc_output

# Local Supabase config/data
.supabase/

# ==========================================
# Flutter / Dart Specific Ignore List
# ==========================================
.dart_tool/
.packages
.pub-cache/
.pub/
/apps/mobile/build/
/apps/mobile/.dart_tool/
/apps/mobile/.packages
/apps/mobile/.flutter-plugins
/apps/mobile/.flutter-plugins-dependencies
/apps/mobile/local.properties
/apps/mobile/ios/Flutter/Generated.xcconfig
/apps/mobile/ios/Flutter/flutter_export_environment.sh
/apps/mobile/android/key.properties
/apps/mobile/android/local.properties

# ==========================================
# Agents cache and CLI lockfiles
# ==========================================
.agents/
!C:\Users\guilh\OneDrive\Documentos\GitHub\OrganizAI\.agents\skills\
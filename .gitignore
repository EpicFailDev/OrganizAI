# ==========================================
# OrganizAI - Root Gitignore for Monorepo
# ==========================================

# ------------------------------------------
# Dependencies
# ------------------------------------------
node_modules/
jspm_packages/
web_resources/
.pub-cache/
.pub/

# ------------------------------------------
# Build Outputs
# ------------------------------------------
dist/
build/
out/
.next/
.nuxt/
/apps/mobile/build/

# ------------------------------------------
# Secrets & Environment Variables (CRITICAL!)
# ------------------------------------------
.env
.env.local

# SSH Keys
ssh/
.env.development.local
.env.test.local
.env.production.local
*.env
*.env.*
!.env.example

# Firebase configs (contain API keys)
google-services.json
GoogleService-Info.plist
firebase_options.dart

# ------------------------------------------
# IDEs, Editors, and OS Metadata
# ------------------------------------------
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store
Thumbs.db
desktop.ini

# ------------------------------------------
# Logs
# ------------------------------------------
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.log

# ------------------------------------------
# Testing & Coverage
# ------------------------------------------
coverage/
.nyc_output/
.dart_tool/
packages

# ------------------------------------------
# Databases
# ------------------------------------------
*.sqlite
*.sqlite3

# ------------------------------------------
# Supabase (local config)
# ------------------------------------------
.supabase/

# ------------------------------------------
# Flutter / Dart
# ------------------------------------------
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
/flutter-plugins
/flutter-plugins-dependencies
*.g.dart
*.freezed.dart
.fvm/

# Android
*.aab
*.jks
*.keystore
key.properties
local.properties
.gradle/
/apps/mobile/android/.gradle/
/apps/mobile/android/app/build/
/apps/mobile/android/local.properties
/apps/mobile/android/key.properties

# iOS
*.mobileprovision
*.cer
 Pods/
Runner.app/
DerivedData/

# macOS
*.dSYM.zip
*.dSYM

# Linux
*.snap

# Windows
*.exe
*.msi
*.msix
*.msm
*.msp

# ------------------------------------------
# Agents & CLI Tools
# ------------------------------------------
.mimocode/
.agents/
!.agents/skills/

# ------------------------------------------
# Temporary Files
# ------------------------------------------
*.tmp
*.tmp_*
*.temp
*.bak
*.backup
*.swp
*~
.metadata

# ------------------------------------------
# Node / Package Manager
# ------------------------------------------
package-lock.json
yarn.lock
pnpm-lock.yaml

# ------------------------------------------
# Environment-specific overrides
# ------------------------------------------
*.local

# ------------------------------------------
# Release artifacts
# ------------------------------------------
*.apk
*.ipa
*.dmg
*.AppImage
*.deb
*.rpm
*.AppBundle

# ------------------------------------------
# Misc
# ------------------------------------------
.vercel/
.netlify/
*.tsbuildinfo
